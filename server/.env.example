PORT=4000
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=12h
CORS_ORIGIN=https://<your-netlify-site>.netlify.app,http://localhost:5173
LOGIN_RATE_LIMIT_MAX=8
RESET_RATE_LIMIT_MAX=10
# Set to "true" to skip the simulated 300-1200ms latency (useful for fast local iteration).
DISABLE_LATENCY=false
